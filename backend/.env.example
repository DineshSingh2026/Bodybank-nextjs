# Dedicated local/staging database for this repo only (never use production DATABASE_URL here).
# PostgreSQL identifier: `bodybank_nextjs` (create with: CREATE DATABASE bodybank_nextjs;)
# URL-encode special characters in the password (e.g. @ → %40).
#
# Example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_ENCODED@localhost:5432/bodybank_nextjs

DATABASE_URL=

# JWT must match the legacy server if you share tokens between stacks.
JWT_SECRET=bodybank-progress-secret-change-in-production
JWT_EXPIRY=7d

# Optional: forward unmatched HTTP to legacy Express (incremental migration).
# LEGACY_FALLBACK_ORIGIN=http://localhost:3000

ADMIN_EMAIL=admin@bodybank.fit
SUPERADMIN_EMAIL=superadmin@bodybank.fit

GOOGLE_CLIENT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BodyBank <noreply@bodybank.fit>

PORT=3002
