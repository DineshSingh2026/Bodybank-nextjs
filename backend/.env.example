# PostgreSQL (same as legacy BodyBank app)
DATABASE_URL=postgresql://localhost:5432/bodybank

# JWT must match the legacy server so tokens issued by either stack validate.
JWT_SECRET=bodybank-progress-secret-change-in-production
JWT_EXPIRY=7d

# Optional: forward any unmatched request to the legacy Express app (incremental migration).
# Example: Nest on 3002, Express on 3000 — set this so /api/auth/* etc. still work.
# LEGACY_FALLBACK_ORIGIN=http://localhost:3000

# Used by GET /api/health (parity with legacy server.js)
ADMIN_EMAIL=admin@bodybank.fit
SUPERADMIN_EMAIL=superadmin@bodybank.fit

# GET /api/config
GOOGLE_CLIENT_ID=

# SMTP (optional — progress POST sends email when configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BodyBank <noreply@bodybank.fit>

PORT=3002
